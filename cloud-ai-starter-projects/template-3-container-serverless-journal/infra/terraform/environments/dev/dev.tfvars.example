aws_region            = "ca-central-1"
app_prefix            = "journal"
env                   = "dev"
compute_mode          = "serverless"
cognito_domain_prefix = ""   # auto-generated by step-3a if empty
container_image_uri   = ""

# AI enrichment — set ai_enabled = "true" and provide your API key to enable
ai_enabled            = "false"
llm_provider          = "groq"                    # "groq" | "bedrock"
groq_api_key          = ""                        # paste your Groq API key here
groq_model_id         = "llama-3.1-8b-instant"   # or llama-3.3-70b-versatile
