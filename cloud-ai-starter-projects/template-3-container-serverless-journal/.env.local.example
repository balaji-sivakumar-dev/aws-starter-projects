# Local development secrets — copy this file to .env.local and fill in your values.
#
#   cp .env.local.example .env.local
#
# .env.local is gitignored and must NEVER be committed.
# It is used by:
#   - Docker Compose (docker-compose.groq.yml reads it automatically via env_file)
#   - scripts/test_groq_local.sh (sourced at the top of the script)
#
# For AWS deployments, secrets are stored in SSM Parameter Store — see:
#   scripts/setup/step-2b-store-secrets.sh

# ── Groq (free tier at https://console.groq.com) ──────────────────────────────
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL_ID=llama-3.1-8b-instant

# ── OpenAI (optional, alternative provider) ───────────────────────────────────
# OPENAI_API_KEY=sk_your_key_here

# ── RAG (set automatically by docker-compose.rag.yml overlay) ────────────────
# These are listed here for reference only — the overlay sets them for you.
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_MODEL=nomic-embed-text
# VECTOR_STORE=chroma
# CHROMA_HOST=chromadb
# CHROMA_PORT=8000

# ── Admin (comma-separated user IDs — in local mode all users are admin) ─────
# ADMIN_USER_IDS=user-id-1,user-id-2
