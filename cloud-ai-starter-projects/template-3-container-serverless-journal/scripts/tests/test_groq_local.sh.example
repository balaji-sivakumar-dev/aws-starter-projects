#!/bin/bash
# Local Groq test script — copy to test_groq_local.sh and fill in your key
#
# Setup (one-time):
#   cp scripts/tests/test_groq_local.sh.example scripts/tests/test_groq_local.sh
#   chmod +x scripts/tests/test_groq_local.sh
#   # Edit test_groq_local.sh and set GROQ_API_KEY
#
# Run:
#   bash scripts/tests/test_groq_local.sh

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(dirname "$(dirname "$SCRIPT_DIR")")"  # scripts/tests/ → scripts/ → repo root

# ── Configure your credentials here ──────────────────────────────────────────
export GROQ_API_KEY="gsk_replace_with_your_key"
export LLM_PROVIDER="groq"
export GROQ_MODEL_ID="llama-3.1-8b-instant"   # or llama-3.3-70b-versatile
# ─────────────────────────────────────────────────────────────────────────────

PYTHON="${REPO_ROOT}/services/api/.venv/bin/python3"

if [ ! -f "$PYTHON" ]; then
  echo "ERROR: venv not found at services/api/.venv"
  echo "  Run: python3 -m venv services/api/.venv && services/api/.venv/bin/pip install boto3"
  exit 1
fi

cd "$REPO_ROOT"
"$PYTHON" scripts/tests/test_ai_gateway_local.py
