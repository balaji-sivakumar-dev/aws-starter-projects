aws_region            = "us-east-1"
app_prefix            = "{{APP_PREFIX}}"
env                   = "dev"

# Compute mode: "serverless" = Lambda + API Gateway only (recommended — no containers needed)
compute_mode          = "serverless"
cognito_domain_prefix = ""   # auto-generated by step-3a if empty
container_image_uri   = ""   # only needed if compute_mode = "container" or "hybrid"

# ── AI enrichment ────────────────────────────────────────────────────────────
# Bedrock is recommended — no external API key, IAM-controlled, pay-per-call.
# See docs/AWS-Cost-Estimate.md for pricing comparison across providers.
#
# LLM pricing (per 1M tokens, input/output):
#   bedrock / nova-lite  →  $0.060 / $0.240  ← cheapest
#   openai / gpt-4o-mini →  $0.150 / $0.600  (better quality, 2.5x cost)
#   openai / gpt-4o      →  $2.500 / $10.00  (best quality, not recommended for RAG)
#
# Embedding pricing (per 1M tokens — same cost, different host):
#   bedrock / titan-embed-text-v2  →  $0.020
#   openai  / text-embedding-3-small → $0.020
#
ai_enabled            = "true"

# ── LLM provider ─────────────────────────────────────────────────────────────
llm_provider          = "bedrock"                  # "bedrock" (recommended) | "openai" | "groq"
bedrock_model_id      = "amazon.nova-lite-v1:0"    # cheapest; switch to amazon.nova-pro-v1:0 for better quality
openai_llm_model      = "gpt-4o-mini"             # only used if llm_provider = "openai"
groq_model_id         = "llama-3.1-8b-instant"    # only used if llm_provider = "groq"

# ── Embedding provider ────────────────────────────────────────────────────────
embedding_provider    = "bedrock"                  # "bedrock" (recommended) | "openai"
openai_embed_model    = "text-embedding-3-small"   # only used if embedding_provider = "openai"

# OpenAI API key — only needed if llm_provider=openai or embedding_provider=openai
# Store via: LLM_PROVIDER=openai ./scripts/setup/step-2b-store-secrets.sh dev
# Then set this to the SSM path value retrieved by Terraform data source.
openai_api_key        = ""

# Groq API key — only needed if llm_provider=groq (legacy option)
groq_api_key          = ""

# ── Admin access ─────────────────────────────────────────────────────────────
# Comma-separated admin email addresses (from .env.users — admin entries).
# Populated automatically when step-2b-store-secrets.sh writes to SSM.
# See docs/AWS-Console-Setup.md for how to read back from SSM and set here.
# Example: admin_emails = "alice@example.com,charlie@example.com"
admin_emails          = ""
